{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RobinZorro86/storm-research/schemas/session.schema.json",
  "title": "STORM research session",
  "type": "object",
  "required": ["topic", "question_types", "phase", "perspectives", "claims"],
  "properties": {
    "topic": {"type": "string", "minLength": 1},
    "scope": {"type": "string"},
    "question_types": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["factual", "causal", "decision", "forecast", "normative"]},
      "uniqueItems": true
    },
    "phase": {"enum": ["framing", "scan", "contradiction", "synthesis", "review", "qa"]},
    "perspectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "reason"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "reason": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "kind", "impact", "status", "sources", "counter_evidence"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "kind": {"enum": ["factual", "interpretive", "normative"]},
          "impact": {"enum": ["high", "medium", "low"]},
          "status": {"enum": ["verified", "unresolved", "rejected"]},
          "evidence_strength": {"enum": ["strong", "moderate", "weak", "none"]},
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "title", "source_type", "independence_group", "opened", "supports_claim"],
              "properties": {
                "url": {"type": "string", "pattern": "^https?://"},
                "title": {"type": "string"},
                "source_type": {"type": "string"},
                "independence_group": {"type": "string"},
                "primary": {"type": "boolean"},
                "opened": {"type": "boolean"},
                "supports_claim": {"type": "boolean"}
              },
              "additionalProperties": true
            }
          },
          "counter_evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "summary": {"type": "string"},
    "implications": {"type": "array", "items": {"type": "string"}},
    "open_questions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
